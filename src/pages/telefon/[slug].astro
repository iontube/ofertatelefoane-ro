---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PhoneCard from '../../components/PhoneCard.astro';
import products from '../../data/telefoane.json';

const MIN_BRAND = 4;
const brandCount = {};
for (const x of products) if (x.brandSlug) brandCount[x.brandSlug] = (brandCount[x.brandSlug] || 0) + 1;

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const money = (n) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const enc = (s) => Buffer.from(s, 'utf8').toString('base64');
const year = new Date().getFullYear();
const title = `${p.name} – preț și oferte ${year} | OfertaTelefoane.ro`;
const desc = `${p.name}: ${p.offerCount > 1 ? `${p.offerCount} oferte, ` : ''}de la ${money(p.price)}. Specificații, stare (${p.condition === 'refurb' ? p.specs.Stare : 'nou'}) și unde îl cumperi cel mai ieftin.`;
const hasBrandPage = p.brandSlug && brandCount[p.brandSlug] >= MIN_BRAND;
const related = products.filter((x) => x.brandSlug === p.brandSlug && x.band === p.band && x.slug !== p.slug).slice(0, 8);
const off = p.oldPrice ? Math.round((1 - p.price / p.oldPrice) * 100) : 0;
const prices = p.offers.map((o) => o.price);
const schema = [
  { '@context': 'https://schema.org', '@type': 'Product', name: p.name, image: p.img, ...(p.brand ? { brand: { '@type': 'Brand', name: p.brand } } : {}), description: p.prose.intro.slice(0, 300),
    offers: { '@type': 'AggregateOffer', priceCurrency: 'RON', lowPrice: Math.min(...prices).toFixed(2), highPrice: Math.max(...prices).toFixed(2), offerCount: p.offerCount, availability: 'https://schema.org/InStock', url: `https://ofertatelefoane.ro/telefon/${p.slug}/` } },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: p.prose.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasă', item: 'https://ofertatelefoane.ro/' },
    { '@type': 'ListItem', position: 2, name: 'Oferte telefoane', item: 'https://ofertatelefoane.ro/oferte/' },
    ...(hasBrandPage ? [{ '@type': 'ListItem', position: 3, name: p.brand, item: `https://ofertatelefoane.ro/brand/${p.brandSlug}/` }] : []),
    { '@type': 'ListItem', position: hasBrandPage ? 4 : 3, name: p.name, item: `https://ofertatelefoane.ro/telefon/${p.slug}/` },
  ] },
];
---
<Layout title={title} description={desc} modified={p.modified}>
  <Nav />
  <section class="ph-sec">
    <div class="container">
      <nav class="crumb"><a href="/">Acasă</a> › <a href="/oferte/">Oferte telefoane</a> ›{hasBrandPage && <> <a href={`/brand/${p.brandSlug}/`}>{p.brand}</a> ›</>} <span>{p.name}</span></nav>

      <article class="po">
        <div class="po__media"><img src={p.img} alt={p.name} width="420" height="420" fetchpriority="high" decoding="async" /></div>
        <div class="po__info">
          <div class="po__tags">
            {p.brand && (hasBrandPage ? <a class="po__brand" href={`/brand/${p.brandSlug}/`}>{p.brand}</a> : <span class="po__brand">{p.brand}</span>)}
            <span class={`pc__cond pc__cond--${p.condition}`}>{p.condition === 'refurb' ? `Refurbished · ${p.specs.Stare}` : 'Nou sigilat'}</span>
          </div>
          <h1 class="po__h1">{p.name}</h1>
          <div class="po__price"><span class="po__from">{p.offerCount > 1 ? 'de la ' : ''}</span><span class="po__now">{money(p.price)}</span>{p.oldPrice && <s>{money(p.oldPrice)}</s>}{off > 0 && <span class="po__off">-{off}%</span>}</div>
          <p class="po__stock">Cel mai mic preț la <a class="po__merch" href={`/magazin/${p.merchantSlug}/`}><strong>{p.merchantName}</strong></a></p>
          <button class="po__cta" data-o={enc(p.slug)} type="button">Vezi oferta la {p.merchantName} →</button>
          <p class="po__note">Preț actualizat periodic · link afiliat</p>
        </div>
      </article>

      {p.offers.length > 1 && (
        <section class="po-block">
          <div class="section-header"><span class="section-header__tag">{p.offers.length} oferte</span><h2>Vezi oferta la fiecare magazin</h2></div>
          <div class="offers">
            {p.offers.map((o, i) => (
              <div class="offer">
                <span class="offer__shop">{o.merchantName}</span>
                <span class="offer__price">{money(o.price)}{o.oldPrice && <s>{money(o.oldPrice)}</s>}</span>
                {i === 0 && <span class="offer__best">cel mai mic</span>}
                <button class="offer__btn" data-o={enc(o.outKey)} type="button">Vezi oferta →</button>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="po-block">
        <div class="section-header"><span class="section-header__tag">Despre</span><h2>Despre {p.name}</h2></div>
        <div class="guide"><p>{p.prose.intro}</p>{p.prose.guide.map((g) => <p>{g}</p>)}</div>
      </section>

      <section class="po-block">
        <div class="section-header"><span class="section-header__tag">Specificații</span><h2>Specificații {p.name}</h2></div>
        <div class="guide"><table class="spec-tbl"><tbody>{Object.entries(p.specs).map(([k, v]) => <tr><th>{k}</th><td>{v}</td></tr>)}</tbody></table></div>
      </section>

      <section class="po-block po-faq">
        <div class="section-header"><span class="section-header__tag">FAQ</span><h2>Întrebări frecvente despre {p.name}</h2></div>
        <div class="faq-list">{p.prose.faq.map((f) => (
          <div class="faq-item">
            <button class="faq-item__q" aria-expanded="false">{f.q}<span class="faq-item__icon">+</span></button>
            <div class="faq-item__a">{f.a}</div>
          </div>
        ))}</div>
      </section>

      {related.length > 0 && (
        <section class="po-block">
          <div class="section-header"><span class="section-header__tag">Similare</span><h2>Alte telefoane {p.brand} similare</h2></div>
          <div class="products-grid">{related.map((r) => <PhoneCard p={r} />)}</div>
        </section>
      )}
    </div>
  </section>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
