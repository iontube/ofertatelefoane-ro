---
const updated = new Date().toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' });
---
<section class="hero">
  <div class="container hero__content">
    <div class="hero__badge">Actualizat {updated}</div>
    <h1>Top Telefoane 2026<br/>Comparatii si <span>Recomandari Reale</span></h1>
    <p class="hero__subtitle">Am testat si analizat cele mai bune telefoane din 2026. De la flagship-uri premium pana la telefoane ieftine care merita fiecare leu. Alege informat.</p>
    <div class="hero__actions">
      <a href="#top-telefoane" class="btn btn--primary">Vezi Top Telefoane 2026</a>
      <a href="#cum-alegi" class="btn btn--secondary">Cum Alegi un Telefon</a>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <div class="hero__stat-value">23</div>
        <div class="hero__stat-label">Telefoane analizate</div>
      </div>
      <div class="hero__stat">
        <div class="hero__stat-value">4</div>
        <div class="hero__stat-label">Categorii de buget</div>
      </div>
      <div class="hero__stat">
        <div class="hero__stat-value">2026</div>
        <div class="hero__stat-label">Actualizat</div>
      </div>
    </div>
  </div>
</section>
