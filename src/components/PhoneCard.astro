---
interface Props { p: any }
const { p } = Astro.props;
const money = (n: number) => Number(n).toLocaleString('ro-RO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' lei';
const off = p.oldPrice ? Math.round((1 - p.price / p.oldPrice) * 100) : 0;
---
<article class="product-card pc">
  <span class={`pc__cond pc__cond--${p.condition}`}>{p.condition === 'refurb' ? (p.specs?.Stare || 'Refurbished') : 'Nou'}</span>
  {off > 0 && <span class="product-card__badge">-{off}%</span>}
  <a class="product-card__image" href={`/telefon/${p.slug}/`} aria-label={p.name}>
    <img src={p.img} alt={p.name} width="180" height="180" loading="lazy" decoding="async" />
  </a>
  <div class="product-card__body">
    <a href={`/telefon/${p.slug}/`}><h3 class="product-card__name">{p.name}</h3></a>
    <div class="product-card__specs">
      {Object.entries(p.specs).filter(([k]) => k !== 'Brand' && k !== 'Stare').slice(0, 3).map(([, v]) => <span class="product-card__spec">{v}</span>)}
    </div>
    <div class="pc__foot">
      <div class="pc__price">{p.offerCount > 1 && <span class="pc__from">de la</span>}{money(p.price)}</div>
      {p.offerCount > 1 && <span class="pc__offers">{p.offerCount} magazine</span>}
    </div>
    <a href={`/telefon/${p.slug}/`} class="pc__cta">Vezi oferta</a>
  </div>
</article>
