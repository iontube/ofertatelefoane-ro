---
interface Props {
  name: string;
  slug: string;
  image: string;
  affiliate: string;
  specs: Record<string, string>;
  badge?: string;
}
const { name, slug, image, affiliate, specs, badge } = Astro.props;
---
<article class="product-card" id={slug}>
  {badge && <span class="product-card__badge">{badge}</span>}
  <div class="product-card__image">
    <img src={image} alt={name} width="180" height="180" loading="lazy" decoding="async" />
  </div>
  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <div class="product-card__specs">
      <span class="product-card__spec">{specs.procesor}</span>
      <span class="product-card__spec">{specs.display?.split(',')[0]}</span>
      <span class="product-card__spec">{specs.baterie}</span>
      <span class="product-card__spec">{specs.ram} RAM</span>
    </div>
    <a href={affiliate} class="product-card__cta" target="_blank" rel="nofollow noopener sponsored">Vezi Oferta</a>
  </div>
</article>
